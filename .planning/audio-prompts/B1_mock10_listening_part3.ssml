  <!-- Gespräch 4: Verein — Vorsitzender erklärt, dass Mitglieder online abstimmen können (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Kann ich bei der Mitgliederversammlung per Vollmacht abstimmen lassen? Ich kann leider nicht persönlich kommen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Dieses Jahr ist es sogar noch einfacher. Wir haben ein Online-Voting eingerichtet. Sie bekommen vorher per E-Mail einen Link und können direkt abstimmen, ohne kommen zu müssen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Oh, das ist praktisch. Und ist das auch sicher?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, jedes Mitglied bekommt einen individuellen Code. Doppelabstimmungen sind technisch ausgeschlossen.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
