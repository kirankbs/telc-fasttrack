  <!-- Gespräch 3: WG-Zimmer-Besichtigung — Zimmer ist hell aber laut wegen Straße (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das Zimmer ist sehr schön und hell. Wie ist das hier mit Lärm?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich muss ehrlich sein: Die Straße davor ist tagsüber recht laut, weil es eine Hauptstraße ist. Abends wird es ruhiger, aber morgens ab 7 Uhr kann der Verkehr schon störend sein.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das ist ein Problem für mich, ich schlafe gerne lang. Gibt es ein anderes freies Zimmer im Haus?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Im Hinterhaus gibt es noch ein Zimmer, das ist ruhiger, aber leider auch kleiner und dunkler.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
