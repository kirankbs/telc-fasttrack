  <!-- Gespräch 5: Arbeitssuche — Frau erklärt dem Berater, dass sie Halbzeit arbeiten möchte wegen Kind (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich möchte gerne wieder in den Beruf einsteigen, aber ich kann nur halbtags arbeiten.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Kein Problem. Was ist der Grund für die Teilzeit?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich habe ein kleines Kind, das ich nachmittags betreuen muss. Morgens geht es in die Kita, bis 13 Uhr.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Das verstehe ich. In Ihrem Bereich als Buchhalterin gibt es tatsächlich einige Stellen mit flexiblen Arbeitszeiten. Ich schaue gleich, was wir aktuell in unserem System haben.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das wäre wunderbar. Ich bin auch bereit, gelegentlich ins Homeoffice zu wechseln, falls nötig.</prosody>
  </voice>
