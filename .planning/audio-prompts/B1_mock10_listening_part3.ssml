  <!-- Gespräch 2: Kaufhaus — Mann sucht Krawatte als Geschenk, Beratung empfiehlt Seidenkrawatte (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich suche eine Krawatte als Geschenk für meinen Vater. Er arbeitet in einer Bank.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Für ein konservatives Arbeitsumfeld wie eine Bank empfehle ich eine klassische Seidenkrawatte in Dunkelblau oder Bordeaux. Die ist immer passend und elegant.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Und was kostet so eine Seidenkrawatte?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wir haben gute Qualität ab 45 Euro. Wenn es eine Designerkrawatte sein soll, beginnt das ab 90 Euro aufwärts.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Dann nehme ich die für 45 Euro in Dunkelblau.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
