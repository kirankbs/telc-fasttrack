  <!-- Gespräch 2: Bahnhof — Frau fragt nach dem richtigen Gleis (correct: a - Gleis 4) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Entschuldigung, ich suche den Zug nach Köln. Welches Gleis ist das?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Der Zug nach Köln fährt von Gleis 4 ab. Aber schauen Sie auf die Anzeigetafel – manchmal wechselt das Gleis kurzfristig.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ah, Gleis 4, danke. Und wissen Sie, ob der Zug pünktlich ist?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Soweit ich weiß schon. Auf der Tafel steht nichts von Verspätung.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
