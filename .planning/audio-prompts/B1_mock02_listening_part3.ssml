  <!-- Gespräch 1: Arztpraxis — Patientin bittet um Termin für Impfung (correct: b - Impftermin) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Morgen, Praxis Dr. Müller, was kann ich für Sie tun?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Morgen. Ich war letzten Monat wegen Rückenschmerzen bei Ihnen. Ich wollte eigentlich fragen, ob ich auch für eine Grippeimpfung vorbeikommen kann.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Natürlich, für die Impfung brauchen Sie einen kurzen Termin. Wir hätten nächsten Dienstag um 9:30 Uhr frei.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Das passt prima. Ich komme dann am Dienstag.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Morgen, Praxis Dr. Müller, was kann ich für Sie tun?</prosody>
