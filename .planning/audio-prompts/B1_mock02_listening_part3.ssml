  <!-- Gespräch 4: Kollegen — Frau fragt nach Firmenparkplatz, der ab nächster Woche für Besucher reserviert ist (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Hast du die E-Mail von der Geschäftsführung gelesen? Über den Parkplatz?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, die Hälfte der Stellplätze wird ab nächster Woche für Kundenbesuche reserviert. Wir Mitarbeiter müssen dann das Parkhaus nebenan nutzen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das Parkhaus kostet aber Geld. Übernimmt die Firma das?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">In der E-Mail stand nichts davon. Das müssen wir wohl selbst bezahlen, leider.</prosody>
  </voice>
