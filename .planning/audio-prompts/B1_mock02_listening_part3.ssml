  <!-- Gespräch 3: Restaurant — Paar kann nicht bezahlen, weil Kartenterminal defekt ist (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Können wir bitte zahlen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Natürlich. Das macht zusammen 47 Euro 60. Möchten Sie mit Karte zahlen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, mit EC-Karte bitte.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Oh, leider funktioniert unser Kartenterminal gerade nicht. Es tut mir sehr leid – ist eine Barzahlung möglich?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Hm, ich glaube, ich habe noch Bargeld. Einen Moment bitte.</prosody>
