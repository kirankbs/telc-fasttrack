  <!-- Gespräch 5: Reisebüro — Kundin bucht Urlaub nach Griechenland, will All-inclusive (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich möchte gerne Urlaub machen. Am liebsten Griechenland, zwei Wochen im August.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wunderbar. Haben Sie eine Präferenz für das Verpflegungsangebot? Nur Frühstück, Halbpension oder All-inclusive?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Am liebsten All-inclusive. Dann muss ich mir um nichts mehr kümmern und weiß genau, was ich ausgebe.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Sehr gute Wahl. Ich zeige Ihnen hier einige Angebote auf Kreta und Rhodos, die sehr beliebt sind.</prosody>
  </voice>
