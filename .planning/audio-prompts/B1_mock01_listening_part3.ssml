  <!-- Gespräch 1: Autowerkstatt — Frau fragt ob Wagen abholbereit ist (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Tag, hier ist Schmidt. Ich wollte nur kurz nachfragen, ob mein Wagen schon fertig ist und ich ihn heute noch abholen kann.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Tag, Frau Schmidt. Ja, wir haben die Inspektion gerade abgeschlossen. Sie können das Fahrzeug ab 16 Uhr abholen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wunderbar, vielen Dank. Bis nachher dann.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
