  <!-- Gespräch 4: Vater-Sohn — Vater wartet auf wichtigen Anruf vom Chef (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Papa, kannst du mich jetzt gleich zum Flughafen bringen? Mein Flug geht in zwei Stunden.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich warte noch auf einen dringenden Anruf von meinem Chef – sobald das erledigt ist, bringe ich dich selbstverständlich zum Flughafen. Das kann nicht mehr lange dauern.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Okay, aber bitte nicht zu lange, ich brauche noch Zeit zum Einchecken.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Keine Sorge, wir schaffen das noch gut.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
