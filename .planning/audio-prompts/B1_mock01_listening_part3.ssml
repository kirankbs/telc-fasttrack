  <!-- Gespräch 2: Zwei Freundinnen — verschieben Treffen auf nächste Woche (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Lisa, hast du Samstag Zeit? Ich dachte, wir könnten ins Kino gehen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Samstag geht leider nicht, ich habe schon was. Und Sonntag bin ich auch verplant.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Okay, dann lass uns das einfach auf nächste Woche verschieben – da passt es uns beiden besser.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, gute Idee. Nächste Woche Mittwoch vielleicht?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Passt mir gut. Abgemacht!</prosody>
  </voice>
  <break time="2s"/>
