  <!-- Gespräch 5: Freunde — planen eine Wanderung, einer hat schlechte Schuhe, leiht sich welche (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich freue mich schon auf die Wanderung am Samstag. Wie lange ist die Strecke?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Etwa 15 Kilometer, aber mit schönen Aussichten. Hast du gute Wanderschuhe?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ehrlich gesagt nicht. Ich habe nur normale Turnschuhe. Meinst du, das geht?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Bei 15 Kilometern und dem unebenen Gelände? Ich würde dir meine alten Wanderschuhe leihen, die passen dir bestimmt. Wir haben doch die gleiche Größe.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Oh super, das wäre toll! Danke dir.</prosody>
  </voice>
  <break time="2s"/>
