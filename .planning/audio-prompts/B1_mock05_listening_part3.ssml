  <!-- Gespräch 4: Bibliothek — Buch bereits ausgeliehen, Vormerken möglich, Wartezeit 2 Wochen (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich suche das Buch "Der Vorleser" von Bernhard Schlink. Haben Sie es?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Einen Moment... Das Buch ist gerade ausgeliehen. Ich kann es aber gerne für Sie vormerken. Die voraussichtliche Wartezeit beträgt etwa zwei Wochen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Zwei Wochen ist in Ordnung. Wie werde ich dann benachrichtigt?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Per E-Mail oder SMS, ganz wie Sie möchten. Dafür brauche ich Ihren Bibliotheksausweis.</prosody>
  </voice>
