  <!-- Gespräch 2: Einkaufszentrum — Frau fragt wo Fundbüro ist, muss Portemonnaie abholen (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Entschuldigung, gibt es hier ein Fundbüro? Ich glaube, ich habe mein Portemonnaie verloren.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, das Fundbüro befindet sich im Erdgeschoss, neben dem Kundendienst. Das ist direkt beim Haupteingang links.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Oh prima, danke! Ich hoffe, es wurde abgegeben.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wir hatten heute schon einige Abgaben. Schauen Sie am besten direkt nach.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Entschuldigung, gibt es hier ein Fundbüro? Ich glaube, ich habe mein Portemonnaie verloren.</prosody>
