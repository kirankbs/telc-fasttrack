  <!-- Gespräch 1: Hotel — Gast möchte verlängern, Zimmer ist aber belegt, Alternative angeboten (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Morgen. Ich möchte meinen Aufenthalt gerne um zwei Nächte verlängern. Ist das möglich?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Leider ist Ihr Zimmer für morgen schon reserviert. Wir könnten Ihnen aber ein gleichwertiges Zimmer in der nächsten Etage anbieten, falls das für Sie in Ordnung ist.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, das ist mir egal, welches Zimmer. Hauptsache ich kann bleiben.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wunderbar, ich ändere das gleich für Sie. Der Preis bleibt der gleiche.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
