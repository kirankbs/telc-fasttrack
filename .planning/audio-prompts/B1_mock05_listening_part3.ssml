  <!-- Gespräch 3: Wohnungssuche — Makler sagt, Wohnung ist zu groß für WG, Vermieter lehnt WG ab (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich interessiere mich für die Dreizimmerwohnung. Ich würde gerne mit zwei Freunden eine WG gründen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das ist leider ein Problem. Der Eigentümer vermietet die Wohnung grundsätzlich nicht an Wohngemeinschaften. Er bevorzugt Familien oder Einzelpersonen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Kann man da gar nichts machen? Wir sind alle Berufstätige mit festen Einkommen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich verstehe, aber der Vermieter ist da sehr bestimmt. Leider können wir daran nichts ändern. Soll ich Ihnen andere Wohnungen zeigen, die für WGs geeignet sind?</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich interessiere mich für die Dreizimmerwohnung. Ich würde gerne mit zwei Freunden eine WG gründen.</prosody>
  </voice>
