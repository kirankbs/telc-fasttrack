  <!-- Gespräch 1: Supermarkt-Rückgabe — Artikel ohne Kassenbon, nur Umtausch möglich (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich möchte diese Hose zurückgeben. Sie passt leider nicht.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Haben Sie den Kassenbon dabei?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Nein, den habe ich leider nicht mehr gefunden.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ohne Kassenbon kann ich leider kein Geld zurückgeben. Ich kann Ihnen aber einen Umtauschbon ausstellen, damit können Sie sich etwas Gleichwertiges aussuchen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Okay, dann nehme ich den Umtauschbon.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
