  <!-- Gespräch 5: Telefonat — Frau möchte einen Handwerker beauftragen, aber erst nach Kostenvoranschlag (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Tag, ich habe ein Problem mit meiner Heizung. Können Sie das reparieren?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, das ist kein Problem. Ich würde nächste Woche vorbeikommen und mir das anschauen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Können Sie mir vorher sagen, was das ungefähr kostet?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Das kann ich erst sagen, wenn ich mir die Heizung angesehen habe. Ich erstelle Ihnen dann vor Ort einen kostenlosen Kostenvoranschlag. Erst dann entscheiden Sie, ob ich anfange.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Gut, so machen wir das. Wann genau nächste Woche?</prosody>
  </voice>
  <break time="2s"/>
