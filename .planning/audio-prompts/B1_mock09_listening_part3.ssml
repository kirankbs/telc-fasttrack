  <!-- Gespräch 3: Notruf — Frau schildert Unfall, Rettung kommt in 8 Minuten (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Hier ist ein Unfall passiert! Ein Fahrradfahrer wurde angefahren, er liegt auf der Straße!</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Bleiben Sie ruhig. Wo genau sind Sie?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">In der Bahnhofstraße, Ecke Lindenweg. Der Mann ist bei Bewusstsein, aber sein Bein sieht schlimm aus.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Gut. Rühren Sie ihn nicht an. Der Rettungswagen ist in ungefähr acht Minuten bei Ihnen. Können Sie in der Nähe bleiben?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, ich bleibe hier.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
