  <!-- Gespräch 2: Freunde — planen Geburtstagsfeier, einigen sich auf Restaurantbesuch (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Was machen wir für Peters Geburtstag? Ich dachte an eine große Party bei mir zu Hause.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Eine Party ist schön, aber wir sind ja nur zu siebt. Was hältst du davon, einfach zusammen essen zu gehen? Dann hat niemand Aufwand mit Vorbereitung und Putzen danach.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guter Punkt. Peter mag das neue italienische Restaurant sehr. Was denkst du?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Das klingt perfekt. Dann reserviere ich dort einen Tisch für sieben Personen. Freitagabend?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, Freitag ist gut. Mach das!</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Was machen wir für Peters Geburtstag? Ich dachte an eine große Party bei mir zu Hause.</prosody>
