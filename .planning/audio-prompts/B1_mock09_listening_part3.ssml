  <!-- Gespräch 4: Hochschule — Student fragt nach Praktikumsanerkennung (correct: b - nur wenn Praktikum mindestens 8 Wochen) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich habe letzten Sommer ein Praktikum gemacht. Kann das für mein Studium anerkannt werden?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das hängt von der Länge ab. Praktika werden nur anerkannt, wenn sie mindestens acht Wochen gedauert haben. War das bei Ihnen der Fall?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, ich war zehn Wochen dort. Ich bringe Ihnen die Bescheinigung mit.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Gut. Bringen Sie bitte außerdem eine kurze Beschreibung der Tätigkeiten. Das reiche ich dann beim Prüfungsamt ein.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
