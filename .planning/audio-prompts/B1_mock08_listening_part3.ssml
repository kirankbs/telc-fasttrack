  <!-- Gespräch 4: Eltern-Lehrer — Tochter ist gut in Mathe, aber Deutsch braucht Verbesserung (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wie läuft es bei meiner Tochter Laura so in der Schule?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">In Mathematik ist Laura wirklich sehr stark, eine der besten in der Klasse. In Deutsch hingegen hat sie noch etwas Nachholbedarf, besonders beim schriftlichen Ausdruck.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Was können wir zu Hause tun?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Regelmäßiges Lesen hilft enorm. Vielleicht 20 bis 30 Minuten täglich. Und wenn Sie möchten, kann ich Ihnen ein paar Buchempfehlungen für ihr Alter mitgeben.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wie läuft es bei meiner Tochter Laura so in der Schule?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">In Mathematik ist Laura wirklich sehr stark, eine der besten in der Klasse. In Deutsch hingegen hat sie noch etwas Nachholbedarf, besonders beim schriftlichen Ausdruck.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Was können wir zu Hause tun?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Regelmäßiges Lesen hilft enorm. Vielleicht 20 bis 30 Minuten täglich. Und wenn Sie möchten, kann ich Ihnen ein paar Buchempfehlungen für ihr Alter mitgeben.</prosody>
  </voice>
  <break time="2s"/>

  <!-- Gespräch 5: Straße — Mann fragt nach Weg zur Universität (correct: a - geradeaus, dann links) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Entschuldigung, können Sie mir sagen, wie ich zur Technischen Universität komme?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, natürlich. Gehen Sie diese Straße etwa 300 Meter geradeaus bis zur großen Kreuzung. Dann biegen Sie links ab in die Universitätsallee. Nach 200 Metern sehen Sie das Hauptgebäude auf der rechten Seite.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Also geradeaus und dann links?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Genau. Und wenn Sie sich unsicher sind, gibt es auf dem Weg ein blaues Schild mit der Aufschrift "TU".</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Entschuldigung, können Sie mir sagen, wie ich zur Technischen Universität komme?</prosody>
  </voice>
