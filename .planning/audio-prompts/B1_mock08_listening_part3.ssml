  </voice>
  <break time="2s"/>

  <!-- Gespräch 3: Markt — Frau kauft Käse, bekommt 100g mehr, Händler korrigiert Preis (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich hätte gerne 200 Gramm von dem Bergkäse, bitte.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Einen Moment... so, das sind 300 Gramm geworden. Ist das in Ordnung, oder soll ich etwas abschneiden?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">300 Gramm ist auch gut. Was kostet das dann?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Der Käse kostet 18 Euro pro Kilo, also macht das für 300 Gramm 5 Euro 40. Darf ich ihn einpacken?</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
