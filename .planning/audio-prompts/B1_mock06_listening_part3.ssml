  <!-- Gespräch 5: Supermarkt Beschwerde — Kassiererin erklärt, dass Rabattmarken nicht mehr gültig sind (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich habe hier drei Rabattmarken. Kann ich die jetzt einlösen?</prosody>
