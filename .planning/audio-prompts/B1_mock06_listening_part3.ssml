  <!-- Gespräch 2: Sprachkurs-Anmeldung — Intensivkurs, tägliche Unterricht, 4 Wochen (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Morgen, ich möchte mein Englisch aufbessern. Was bieten Sie an?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wir haben Wochendkurse, die einmal pro Woche stattfinden, und Intensivkurse mit täglich vier Stunden Unterricht. Wie schnell möchten Sie Fortschritte machen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ich habe nur vier Wochen Zeit. Welcher Kurs ist dann besser?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Für vier Wochen empfehle ich definitiv den Intensivkurs. Bei täglichem Unterricht machen Sie erheblich schnellere Fortschritte.</prosody>
  </voice>
