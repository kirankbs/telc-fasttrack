  <!-- Gespräch 1: Telefon-Reklamation — Gerät ist kaputt, Garantie abgelaufen, Reparatur teurer als Neukauf (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Tag, ich habe hier ein Smartphone, das nicht mehr startet. Das ist erst 18 Monate alt.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Lassen Sie mich das ansehen. Hm, das Display ist gebrochen und es gibt Feuchtigkeitsschäden. Das ist leider nicht unter die Garantie abgedeckt.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Was kostet dann die Reparatur?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Die Reparatur würde rund 280 Euro kosten. Das neue Modell bekommen Sie hier aber schon für 230 Euro. Ehrlich gesagt würde ich Ihnen eher zum Neukauf raten.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
