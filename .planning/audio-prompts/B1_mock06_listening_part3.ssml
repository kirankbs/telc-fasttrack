  <!-- Gespräch 3: Camping — Platz ausgebucht, Stellplatz mit Strom nur mit Jahresticket (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Tag, haben Sie noch Stellplätze für ein Wohnmobil, mit Stromanschluss?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Für diese Woche sind leider alle Plätze mit Strom vergeben. Wir haben noch zwei einfache Plätze ohne Strom frei.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Und gibt es andere Campingplätze in der Nähe, die Sie empfehlen können?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
