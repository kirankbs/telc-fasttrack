  <!-- Question 5: Supermarkt früher schließen -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Aufgabe 5.</prosody>
    <break time="1s"/>
  </voice>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">
      Liebe Kundinnen und Kunden,
      heute schließen wir ausnahmsweise um 18 Uhr —
      das sind zwei Stunden früher als sonst.
      Bitte achten Sie auf die Zeit und kommen Sie rechtzeitig zur Kasse.
      Wir danken für Ihr Verständnis und freuen uns auf Ihren nächsten Besuch.
    </prosody>
  </voice>

