  <!-- Question 4: Konzert 19:30 Uhr -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Aufgabe 4.</prosody>
    <break time="1s"/>
  </voice>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">
      Herzlich willkommen im Konzerthaus der Stadt.
      Das Konzert heute Abend beginnt um 19 Uhr 30.
      Bitte kommen Sie rechtzeitig und nehmen Sie Ihre Plätze ein.
      Das Fotografieren während der Vorstellung ist leider nicht erlaubt.
      Wir wünschen Ihnen einen schönen Abend.
    </prosody>
  </voice>

  <break time="2s"/>

  <voice name="de-DE-Wavenet-C">
