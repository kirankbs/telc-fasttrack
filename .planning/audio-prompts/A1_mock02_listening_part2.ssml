  <break time="3s"/>

  <!-- Question 3: Arztpraxis Freitag -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Aufgabe 3.</prosody>
    <break time="1s"/>
  </voice>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">
      Sie haben die Praxis Dr. Berger angerufen.
      Unsere Praxis ist montags bis donnerstags von 8 bis 18 Uhr geöffnet.
      Freitags sind wir nur bis 13 Uhr für Sie da.
      Am Wochenende ist die Praxis geschlossen.
      Für dringende Fälle wenden Sie sich bitte an den ärztlichen Bereitschaftsdienst.
    </prosody>
  </voice>

  <break time="2s"/>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören den Text jetzt noch einmal.</prosody>
    <break time="2s"/>
  </voice>

