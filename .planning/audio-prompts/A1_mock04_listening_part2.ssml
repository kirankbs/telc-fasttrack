    </prosody>
  </voice>

  <break time="3s"/>

  <!-- Question 5: Bus 7 fährt am Sonntag mit reduziertem Fahrplan -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Aufgabe 5.</prosody>
    <break time="1s"/>
  </voice>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">
      Informationen zur Buslinie 7.
      Linie 7 fährt täglich, auch an Sonn- und Feiertagen —
      jedoch mit reduziertem Fahrplan.
      Am Sonntag fahren die Busse seltener,
      alle 30 Minuten statt alle 15 Minuten.
      Aktuelle Fahrpläne finden Sie an den Haltestellen.
    </prosody>
  </voice>

  <break time="2s"/>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören den Text jetzt noch einmal.</prosody>
    <break time="2s"/>
  </voice>

  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">
      Informationen zur Buslinie 7.
      Linie 7 fährt täglich, auch an Sonn- und Feiertagen —
      jedoch mit reduziertem Fahrplan.
      Am Sonntag fahren die Busse seltener,
      alle 30 Minuten statt alle 15 Minuten.
