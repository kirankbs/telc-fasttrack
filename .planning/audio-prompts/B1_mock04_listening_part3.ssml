  <!-- Gespräch 2: Schule — Elternteil fragt warum Kind nicht am Ausflug teilnehmen kann (correct: a - krank) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Morgen, Herr Decker. Ich wollte kurz fragen, warum mein Sohn Leo nicht am Schulausflug teilnehmen kann?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Morgen, Frau Maier. Leo hat leider zu viele unentschuldigte Fehlstunden in letzter Zeit. Das ist eine schulische Konsequenz, die wir leider umsetzen müssen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Aber Leo war krank! Ich habe jedes Mal ein Attest gebracht.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ich schaue das nach. Wenn alle Atteste vorliegen, sind die Fehlstunden entschuldigt und Leo darf selbstverständlich mitfahren. Bitte kommen Sie kurz ins Büro.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
