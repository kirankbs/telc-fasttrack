  <!-- Gespräch 3: Café — Kellner erklärt, dass Tagesgericht Kartoffeln statt Reis enthält (correct: c) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 3.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Was ist denn heute das Tagesgericht?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wir haben heute Hähnchen in Tomatensoße. Auf der Speisekarte steht noch Reis dazu, aber wir haben heute Kartoffeln als Beilage, da der Reislieferant nicht pünktlich war.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Kein Problem, Kartoffeln passen auch gut. Ich nehme das Tagesgericht.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Sehr gerne. Trinken Sie etwas dazu?</prosody>
  </voice>
