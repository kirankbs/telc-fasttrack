  <!-- Gespräch 1: Jobcenter — Frau erklärt, dass man die Unterlagen persönlich abgeben muss (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Guten Tag, ich möchte Arbeitslosengeld beantragen. Kann ich die Unterlagen per Post schicken?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Für die erste Antragstellung müssen Sie persönlich vorbeikommen. Die Unterlagen können wir nicht per Post annehmen, da wir Ihren Ausweis im Original sehen müssen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Verstehe. Muss ich dann einen Termin machen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, bitte vereinbaren Sie vorher einen Termin über unsere Hotline oder online. Ohne Termin kann es sehr lange Wartezeiten geben.</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
