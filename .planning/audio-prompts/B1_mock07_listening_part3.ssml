  <!-- Gespräch 1: Reisebüro — Kundschaft möchte nach Thailand, Agent schlägt Bali vor wegen Preis (correct: b) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 1.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wir möchten in diesem Winter nach Südostasien. Thailand ist unser Wunsch.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Thailand ist wunderbar. Allerdings sind die Flüge im Dezember sehr teuer, fast 1.400 Euro pro Person. Hätten Sie Interesse an Bali? Das ist ähnliche Entfernung, ähnliches Klima, aber deutlich günstiger – etwa 900 Euro.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Bali klingt auch interessant. Ich wusste nicht, dass es so viel günstiger ist.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wir können Ihnen beide Optionen zeigen. Soll ich Angebote für beide Ziele heraussuchen?</prosody>
  </voice>
  <break time="2s"/>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Sie hören das Gespräch jetzt noch einmal.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wir möchten in diesem Winter nach Südostasien. Thailand ist unser Wunsch.</prosody>
  </voice>
