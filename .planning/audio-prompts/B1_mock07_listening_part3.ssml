  <!-- Gespräch 4: Café — Student fragt ob WLAN-Passwort gültig ist (correct: a - neues Passwort) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 4.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Entschuldigung, ich kann mich nicht mit dem WLAN verbinden. Ist das Passwort noch dasselbe?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Oh, wir haben das Passwort letzte Woche geändert. Das neue lautet: Kaffee2026, alles klein, kein Leerzeichen.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Danke! Und funktioniert das auch für alle Geräte?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Ja, das Gäste-WLAN ist für alle Geräte. Bei Problemen helfe ich gerne.</prosody>
