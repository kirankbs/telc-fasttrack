  <!-- Gespräch 5: Telefoninterview Stelle — Bewerberin fragt ob Stelle noch frei ist (correct: b - sie sollen sich schriftlich bewerben) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 5.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Guten Tag, ich habe Ihre Stellenanzeige für den Bürokaufmann gesehen. Ist die Stelle noch frei?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Ja, wir haben die Stelle noch nicht besetzt. Allerdings nehmen wir keine telefonischen Bewerbungen an. Bitte senden Sie uns Ihre Unterlagen per E-Mail – die Adresse steht in der Anzeige.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Alles klar. Bis wann soll ich die Bewerbung schicken?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Am besten bis Ende dieser Woche. Wir starten die Gespräche schon nächste Woche.</prosody>
