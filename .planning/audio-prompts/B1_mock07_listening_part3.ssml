  <!-- Gespräch 2: Fahrschule — Schüler hat Prüfung nicht bestanden, muss nochmal üben (correct: a) -->
  <voice name="de-DE-Wavenet-C">
    <prosody rate="slow">Gespräch 2.</prosody>
    <break time="1s"/>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Wie ist die Prüfung gelaufen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Leider nicht gut. Ich bin durchgefallen. Beim Einparken habe ich einen schwerwiegenden Fehler gemacht und dann bei der Vorfahrt auch noch gezögert.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Das ist schade, aber kein Weltuntergang. Wir üben das Einparken und die Vorfahrtsregeln nochmal gezielt, dann klappt es beim nächsten Versuch bestimmt.</prosody>
  </voice>
  <voice name="de-DE-Wavenet-B">
    <prosody rate="medium">Wann kann ich die Prüfung wiederholen?</prosody>
  </voice>
  <voice name="de-DE-Wavenet-C">
    <prosody rate="medium">Frühestens nach vier Wochen. Ich melde Sie für den nächsten Termin an.</prosody>
  </voice>
  <break time="2s"/>
